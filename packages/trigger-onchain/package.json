{
  "name": "@swati/trigger-onchain",
  "version": "0.1.0",
  "description": "swati <> trigger-onchain",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./deploy": {
      "import": "./dist/deploy.js",
      "types": "./dist/deploy.d.ts"
    },
    "./abi": {
      "import": "./dist/abi.js",
      "types": "./dist/abi.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/deploy.ts src/abi.ts --format esm --dts --out-dir dist",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@swati/core": "workspace:*",
    "viem": "^2.18.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.2.0",
    "vitest": "^2.0.0"
  }
}
