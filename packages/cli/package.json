{
  "name": "@swati/cli",
  "version": "0.1.0",
  "description": "swati <> cli",
  "type": "module",
  "bin": {
    "swati": "./bin/swati.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --out-dir dist && chmod +x bin/swati.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@swati/core": "workspace:*",
    "@swati/registry-onchain": "workspace:*",
    "@swati/resolver-ens": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.2.0",
    "tsx": "^4.16.0",
    "vitest": "^2.0.0"
  }
}
